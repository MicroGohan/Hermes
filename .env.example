# ---- Hermes config ----
# Copia este archivo a  .env  y rellena tus datos.

# Número AUTORIZADO: el TUYO principal, desde donde escribirás al bot.
# Solo dígitos con código de país. Ej. México: 521XXXXXXXXXX
# (se compara por los últimos 10 dígitos, no importa el prefijo 52/521)
ALLOWED_NUMBER=

# Carpeta donde Claude ejecutará las tareas.
WORK_DIR=/home/liwson

# Modo peligroso. true = Claude actúa sin pedir permisos (necesario para que
# ejecute tareas solo, como en consola). Protegido por la whitelist de arriba.
# false = modo permisos por defecto (muchas acciones fallarán en headless).
DANGEROUS_MODE=true

# ---- Transcripción (Whisper) ----
STT_URL=http://127.0.0.1:8000
STT_PORT=8000
STT_MODEL=large-v3-turbo
STT_THREADS=6
STT_LANG=es
STT_COMPUTE=int8
